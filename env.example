# Frontend environment example
# Copy to `.env.local` for local development or add these in Vercel.

# Required for the new multi-tenant system
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional legacy API integration
# Keep this only if you still use the old standalone backend-powered pages.
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Optional legacy websocket integration
# Keep these only if you still use the old realtime socket flows.
NEXT_PUBLIC_WEBSOCKET_ENABLED=true
NEXT_PUBLIC_FREE_TIER=false

# Environment
NODE_ENV=development
